rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper: Verify IDs matches basic characters
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_-]+$');
    }

    match /shared_items/{itemId} {
      allow read: if true;
      allow write: if isValidId(itemId);
    }

    match /shared_config/{configId} {
      allow read: if true;
      allow write: if isValidId(configId);
    }
  }
}
